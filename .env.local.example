# Groq API — obtén tu key en https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Supabase — en Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cron secret — protege los endpoints /api/run-bot y /api/resolve-positions
# Generar con: openssl rand -hex 32
# Agregar también en Vercel → Settings → Environment Variables
CRON_SECRET=your_cron_secret_here
